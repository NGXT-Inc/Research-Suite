# Hosted brain environment. Copy to a secret-store entry or an env file your
# orchestrator mounts. Never commit a filled-in copy.

# --- mode + bind ---
# Forced to `control` by the merv-control entrypoint; set here for
# clarity / when running merv-http directly.
RESEARCH_PLUGIN_MODE=control
RESEARCH_PLUGIN_HTTP_HOST=0.0.0.0
RESEARCH_PLUGIN_HTTP_PORT=8787
# Comma-separated hosted UI origins allowed to call the control API.
RESEARCH_PLUGIN_ALLOWED_ORIGINS=https://research-ui.example.com
# UI base for the merv-client login handoff (auth_url). Unlike CORS origins a
# path suffix is allowed (path-mounted UI); unset falls back to the first
# allowed origin, then the API's own origin.
# RESEARCH_PLUGIN_UI_BASE_URL=https://rapidreview.io/merv

# --- record store (REQUIRED by hosted startup without an explicit dev root) ---
# A postgres:// or postgresql:// URL selects the Postgres dialect. SQLite is
# only available to the explicit local/dev composition.
RESEARCH_PLUGIN_DB_URL=postgresql://USER:PASSWORD@HOST:5432/research_plugin

# --- submitted-byte blob store (REQUIRED by hosted startup) ---
# A bucket name selects the S3 blob store used by the brain for bounded submitted
# bytes. The MCP proxy submits those bytes through private data-plane HTTP routes;
# sandboxes do not use blob presigned URLs. boto3 reads standard AWS_* vars;
# AWS_ENDPOINT_URL_S3 points the brain at MinIO / non-AWS S3 in development.
RESEARCH_PLUGIN_BLOB_BUCKET=merv-blobs
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=us-east-1
# AWS_ENDPOINT_URL_S3=http://minio:9000   # dev only (MinIO); unset on real S3

# --- optional heavy-file storage (object store) ---
# Heavy-file storage is separate from the blob store. The storage-specific
# credentials fall back to AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY when unset.
# RESEARCH_PLUGIN_STORAGE_PROVIDER=s3
# RESEARCH_PLUGIN_STORAGE_BUCKET=merv-storage
# RESEARCH_PLUGIN_STORAGE_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
# RESEARCH_PLUGIN_STORAGE_REGION=auto
# RESEARCH_PLUGIN_STORAGE_ACCESS_KEY_ID=CHANGE_ME
# RESEARCH_PLUGIN_STORAGE_SECRET_ACCESS_KEY=CHANGE_ME
# Presigned heavy-storage URLs are dereferenced by client-side MCP proxies (and
# the deploy doctor), so this endpoint must be reachable from those clients.
# RESEARCH_PLUGIN_STORAGE_ENDPOINT_URL=https://backend.example.com
# AWS_ENDPOINT_URL_S3 may remain a separate brain-internal blob-store endpoint.

# --- centralized MLflow tracking ---
# Hosted control reports this URI to agents for quantitative experiments.
# Point it at the public MLflow reverse-proxy URL for production.
RESEARCH_PLUGIN_MLFLOW_MODE=external
RESEARCH_PLUGIN_MLFLOW_TRACKING_URI=https://backend.example.com/mlflow
# Production hosted control should fail startup rather than let quantitative
# agents run without MLFLOW_TRACKING_URI in mlflow.context.
RESEARCH_PLUGIN_REQUIRE_AGENT_MLFLOW=1
# Optional: backend-internal URI for metrics reads when it differs.
# RESEARCH_PLUGIN_MLFLOW_SERVER_URI=http://mlflow:5000
# Optional: if humans should open a different UI URL than clients use.
# RESEARCH_PLUGIN_MLFLOW_DASHBOARD_URL=https://backend.example.com/mlflow
# Reference Compose only: forwarded to MLflow as --static-prefix when its UI/API
# is served under a path such as /mlflow. The brain does not read this variable.
# RESEARCH_PLUGIN_MLFLOW_STATIC_PREFIX=/mlflow

# --- management SSH key (REQUIRED in production) ---
# Mounted private-key FILE + matching public key for brain management
# operations. The control plane reads this key; it never mints one locally when
# these vars are set. The private key must be readable by the control process
# and 0600/0400 (not group/world-readable). To rotate, drain live sandboxes,
# stop control, replace the mounted keypair, and restart. In-place rotation is
# rejected after startup.
RESEARCH_PLUGIN_MGMT_KEY_PATH=/run/secrets/research_plugin_mgmt_key/key
# Optional when /run/secrets/research_plugin_mgmt_key/key.pub is mounted.
# RESEARCH_PLUGIN_MGMT_PUBLIC_KEY=ssh-ed25519 CHANGE_ME

# --- provider credentials (secret store ONLY in control mode) ---
# In control mode user-machine .env discovery is DISABLED: these must come from
# the provider env file loaded directly by the control service. Point Compose at
# an absolute, host-side file; /dev/null is the record-only default. Set the
# pair(s) for the providers you provision on. Lambda/Thunder deliver HF_TOKEN
# after boot over the management channel; Modal passes it through modal.Secret.
RESEARCH_PLUGIN_PROVIDER_ENV_FILE=/absolute/path/to/provider-secrets.env
# Production hosted control should fail startup when the configured sandbox
# backend cannot pass its lightweight health check.
RESEARCH_PLUGIN_REQUIRE_SANDBOX_BACKEND=1
RESEARCH_PLUGIN_EXECUTION_BACKEND=lambda_labs
# Multi-provider fleets: a comma-separated list configures several providers at
# once behind one multiplexer (agents pick per request with sandbox.request's
# provider field). The single-name var above then selects the default among
# them. One name (or unset) keeps the single-backend path exactly as before.
# RESEARCH_PLUGIN_EXECUTION_BACKENDS=lambda_labs,hyperstack,digitalocean
# RESEARCH_PLUGIN_LAMBDA_API_KEY=CHANGE_ME
# THUNDER_COMPUTE_API_KEY=CHANGE_ME
# MODAL_TOKEN_ID=CHANGE_ME
# MODAL_TOKEN_SECRET=CHANGE_ME
# HF_TOKEN=CHANGE_ME

# --- authentication (Supabase, shared with RapidReview) ---
# The hosted brain verifies the SAME Supabase project RapidReview uses: the
# same accounts sign in to both products, and existing rr_sk_ API keys work.
# JWT secret + URL come from the Supabase dashboard (Settings > API); the
# service-role key (RapidReview calls it SUPABASE_KEY) is needed only for
# rr_sk_ API-key hash lookups. ROTATE the JWT secret + service key before
# first use — historical values leaked into RapidReview git history.
# Unset => the surface boots OPEN with a loud warning; REQUIRE_AUTH=1 makes
# missing config a startup failure instead. See docs/AUTH.md for the runbook.
RESEARCH_PLUGIN_REQUIRE_AUTH=1
# SUPABASE_URL=https://CHANGE_ME.supabase.co
# SUPABASE_JWT_SECRET=CHANGE_ME
# SUPABASE_SERVICE_KEY=CHANGE_ME
# SUPABASE_ANON_KEY=CHANGE_ME

# --- MLflow agent credential (hosted /mlflow gate) ---
# An rr_sk_ API key handed to agents (mlflow.context env + sandbox secrets)
# as MLFLOW_TRACKING_USERNAME/PASSWORD once Caddy forward_auth gates /mlflow.
# RESEARCH_PLUGIN_MLFLOW_AGENT_KEY=rr_sk_CHANGE_ME
