# Template for a local Merv brain's per-user provider credentials.
# Copy this to ~/.config/merv/.env and fill in only the keys you need.

# Default sandbox backend: Lambda Labs
RESEARCH_PLUGIN_LAMBDA_API_KEY=

# Optional sandbox backend: Thunder Compute
RESEARCH_PLUGIN_THUNDER_API_KEY=

# Optional sandbox backend: Modal
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Optional: forwarded to sandboxes for Hugging Face access
HF_TOKEN=
