#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" == /* ]]; then
    SOURCE="$TARGET"
  else
    SOURCE="$DIR/$TARGET"
  fi
done

BIN_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
PLUGIN_DIR="$(cd "$BIN_DIR/.." >/dev/null 2>&1 && pwd)"
# Python resolution. The HTTP backend needs the full requirements.txt deps
# (fastapi, modal, pydantic, httpx, uvicorn), so we fail loud if no venv is
# found instead of silently falling through to a system python that may not
# have them. The user has to set this up once per machine.
if [[ -n "${RESEARCH_PLUGIN_PYTHON:-}" ]]; then
  PYTHON_BIN="$RESEARCH_PLUGIN_PYTHON"
elif [[ -n "${CLAUDE_PLUGIN_DATA:-}" && -x "$CLAUDE_PLUGIN_DATA/.venv/bin/python" ]]; then
  PYTHON_BIN="$CLAUDE_PLUGIN_DATA/.venv/bin/python"
elif [[ -x "$PLUGIN_DIR/.venv/bin/python" ]]; then
  PYTHON_BIN="$PLUGIN_DIR/.venv/bin/python"
else
  cat >&2 <<EOF
merv-http: no Python interpreter with the backend dependencies found.

Looked for, in order:
  \$RESEARCH_PLUGIN_PYTHON              (unset)
  \$CLAUDE_PLUGIN_DATA/.venv/bin/python (per-user data dir)
  $PLUGIN_DIR/.venv/bin/python          (in-tree dev venv)

One-time setup:
  python3 -m venv "$PLUGIN_DIR/.venv"
  "$PLUGIN_DIR/.venv/bin/pip" install -r "$PLUGIN_DIR/requirements.txt"

Or point at any other venv with: export RESEARCH_PLUGIN_PYTHON=/path/to/python
EOF
  exit 1
fi

export PYTHONPATH="$PLUGIN_DIR${PYTHONPATH:+:$PYTHONPATH}"

# Provider/HF credential resolution. Secrets must live OUTSIDE the plugin tree
# so they are never copied into a Claude Code install cache or accidentally
# committed. Priority (first hit wins):
#   1. any explicit provider env file override
#   2. ${CLAUDE_PLUGIN_DATA}/.env                  (Claude Code per-user data dir)
#   3. ${XDG_CONFIG_HOME:-${HOME}/.config}/merv/.env  (XDG standard)
#   4. ${HOME}/.research_plugin/.env               (legacy location)
#   5. $PLUGIN_DIR/.env                            (dev-only; gitignored)
# If none exist, providers may fall back to their native auth.
if [[ -z "${RESEARCH_PLUGIN_LAMBDA_ENV_FILE:-}" \
  && -z "${RESEARCH_PLUGIN_MODAL_ENV_FILE:-}" \
  && -z "${RESEARCH_PLUGIN_THUNDER_ENV_FILE:-}" ]]; then
  for candidate in \
    "${CLAUDE_PLUGIN_DATA:-/__unset__}/.env" \
    "${XDG_CONFIG_HOME:-${HOME}/.config}/merv/.env" \
    "${HOME}/.research_plugin/.env" \
    "$PLUGIN_DIR/.env"; do
    if [[ -f "$candidate" ]]; then
      export RESEARCH_PLUGIN_LAMBDA_ENV_FILE="$candidate"
      export RESEARCH_PLUGIN_MODAL_ENV_FILE="$candidate"
      export RESEARCH_PLUGIN_THUNDER_ENV_FILE="$candidate"
      break
    fi
  done
fi

exec "$PYTHON_BIN" -m backend.transport.http_server "$@"
