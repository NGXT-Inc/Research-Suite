# Template for the research_plugin daemon's per-user credential file.
# Copy this to ~/.config/research-plugin/.env and fill in only the keys you need.

# Default sandbox backend: Lambda Labs
RESEARCH_PLUGIN_LAMBDA_API_KEY=

# Optional sandbox backend: Modal
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Optional: forwarded to sandboxes for Hugging Face access
HF_TOKEN=
