# Control-plane environment (cloud plan §3.4, Phase 9). Copy to a secret store
# entry or an env file your orchestrator mounts — NEVER commit a filled-in copy.
# Only the control-mode variables are documented here; local/daemon modes use a
# different subset (see docs/CONTROL_PLANE_OPERATIONS.md).

# --- mode + bind ---
# Forced to `control` by the research-plugin-control entrypoint; set here for
# clarity / when running research-plugin-http directly.
RESEARCH_PLUGIN_MODE=control
RESEARCH_PLUGIN_HTTP_HOST=0.0.0.0
RESEARCH_PLUGIN_HTTP_PORT=8787

# --- record store (REQUIRED in production) ---
# A postgres:// URL selects the Postgres dialect. Without it the control plane
# falls back to SQLite — fine for dev, NOT for multi-tenant production.
RESEARCH_PLUGIN_DB_URL=postgresql://USER:PASSWORD@HOST:5432/research_plugin

# --- blob store (REQUIRED in production) ---
# A bucket name selects the S3 blob store. Its presign must be a real HTTPS PUT a
# sandbox VM can reach (the parachute depends on it). boto3 reads the standard
# AWS_* vars; AWS_ENDPOINT_URL_S3 points it at MinIO / a non-AWS S3 in dev.
RESEARCH_PLUGIN_BLOB_BUCKET=research-plugin-blobs
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=us-east-1
# AWS_ENDPOINT_URL_S3=http://minio:9000   # dev only (MinIO); unset on real S3

# --- provider credentials (secret store ONLY in control mode) ---
# In control mode user-machine .env discovery is DISABLED: these must come from
# the process env / a mounted secret. Set the pair(s) for the providers you
# provision on. HF_TOKEN is delivered post-boot over the management channel
# (never embedded in VM user_data).
# MODAL_TOKEN_ID=CHANGE_ME
# MODAL_TOKEN_SECRET=CHANGE_ME
# LAMBDA_API_KEY=CHANGE_ME
# HF_TOKEN=CHANGE_ME

# --- optional tuning ---
# Bounded wait for a daemon to execute a cloud task before the reaper falls
# through to the expiry parachute (billing protection beats data recovery).
# RESEARCH_PLUGIN_TASK_RESULT_TIMEOUT=30
