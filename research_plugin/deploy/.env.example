# Control-plane environment (cloud plan §3.4, Phase 9). Copy to a secret store
# entry or an env file your orchestrator mounts — NEVER commit a filled-in copy.
# Only the control-mode variables are documented here; local/daemon modes use a
# different subset (see docs/CONTROL_PLANE_OPERATIONS.md).

# --- mode + bind ---
# Forced to `control` by the research-plugin-control entrypoint; set here for
# clarity / when running research-plugin-http directly.
RESEARCH_PLUGIN_MODE=control
RESEARCH_PLUGIN_HTTP_HOST=0.0.0.0
RESEARCH_PLUGIN_HTTP_PORT=8787
# Comma-separated hosted UI origins allowed to call the control API.
RESEARCH_PLUGIN_ALLOWED_ORIGINS=https://research-ui.example.com

# --- record store (REQUIRED in production) ---
# A postgres:// URL selects the Postgres dialect. Without it the control plane
# falls back to SQLite — fine for dev, NOT for multi-tenant production.
RESEARCH_PLUGIN_DB_URL=postgresql://USER:PASSWORD@HOST:5432/research_plugin

# --- blob store (REQUIRED in production) ---
# A bucket name selects the S3 blob store. Its presign must be a real HTTPS PUT a
# sandbox VM can reach (the parachute depends on it). boto3 reads the standard
# AWS_* vars; AWS_ENDPOINT_URL_S3 points it at MinIO / a non-AWS S3 in dev.
RESEARCH_PLUGIN_BLOB_BUCKET=research-plugin-blobs
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=us-east-1
# AWS_ENDPOINT_URL_S3=http://minio:9000   # dev only (MinIO); unset on real S3

# --- long-term storage (object store) ---
# Heavy-file storage is separate from the blob store. The storage-specific
# credentials fall back to AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY when unset.
# RESEARCH_PLUGIN_STORAGE_PROVIDER=s3
# RESEARCH_PLUGIN_STORAGE_BUCKET=research-plugin-storage
# RESEARCH_PLUGIN_STORAGE_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
# RESEARCH_PLUGIN_STORAGE_REGION=auto
# RESEARCH_PLUGIN_STORAGE_ACCESS_KEY_ID=CHANGE_ME
# RESEARCH_PLUGIN_STORAGE_SECRET_ACCESS_KEY=CHANGE_ME

# --- centralized MLflow tracking ---
# Hosted control reports this URI to agents for quantitative experiments.
# Point it at the public MLflow reverse-proxy URL for production.
RESEARCH_PLUGIN_MLFLOW_MODE=external
RESEARCH_PLUGIN_MLFLOW_TRACKING_URI=https://backend.example.com/mlflow
# Optional: backend-internal URI for metrics reads when it differs.
# RESEARCH_PLUGIN_MLFLOW_SERVER_URI=http://mlflow:5000
# Optional: if humans should open a different UI URL than clients use.
# RESEARCH_PLUGIN_MLFLOW_DASHBOARD_URL=https://backend.example.com/mlflow
# Required when serving the MLflow UI/API under a path such as /mlflow.
# RESEARCH_PLUGIN_MLFLOW_STATIC_PREFIX=/mlflow

# --- management SSH key (REQUIRED in production) ---
# Mounted private key + matching public key for control-plane management
# operations. The control plane reads this key; it never mints one locally when
# these vars are set. The private key must be readable by the control process
# and 0600/0400 (not group/world-readable). Rotate by draining live sandboxes or
# restarting control; in-place rotation is rejected after startup.
RESEARCH_PLUGIN_MGMT_KEY_PATH=/run/secrets/research_plugin_mgmt_key
RESEARCH_PLUGIN_MGMT_PUBLIC_KEY=ssh-ed25519 CHANGE_ME

# --- provider credentials (secret store ONLY in control mode) ---
# In control mode user-machine .env discovery is DISABLED: these must come from
# the process env / a mounted secret. Set the pair(s) for the providers you
# provision on. HF_TOKEN is delivered post-boot over the management channel
# (never embedded in VM user_data).
# THUNDER_COMPUTE_API_KEY=CHANGE_ME
# MODAL_TOKEN_ID=CHANGE_ME
# MODAL_TOKEN_SECRET=CHANGE_ME
# LAMBDA_API_KEY=CHANGE_ME
# HF_TOKEN=CHANGE_ME

# --- optional tuning ---
# Bounded wait for a daemon to execute a cloud task before the reaper falls
# through to the expiry parachute (billing protection beats data recovery).
# RESEARCH_PLUGIN_TASK_RESULT_TIMEOUT=30
