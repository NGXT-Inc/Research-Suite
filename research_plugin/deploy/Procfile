# Process declarations for the Research Plugin split topology (plan Phase 9).
# A reference for a Procfile-driven host (Foreman/Honcho/Heroku-style). The
# control plane and the user-machine daemon are SEPARATE deployments — they
# never run in the same Procfile in production — but both entrypoints are shown
# here so the console-script wiring is documented in one place.

# Cloud control plane (auth on, reaper on, daemon endpoints on). Behind a
# TLS-terminating load balancer. Needs RESEARCH_PLUGIN_DB_URL + _BLOB_BUCKET.
control: research-plugin-control

# User-machine data-plane daemon (rsync on, reaper off). Needs
# RESEARCH_PLUGIN_CONTROL_URL + a 0600 RESEARCH_PLUGIN_CONTROL_TOKEN_FILE.
daemon: research-plugin-daemon
