#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" == /* ]]; then
    SOURCE="$TARGET"
  else
    SOURCE="$DIR/$TARGET"
  fi
done

BIN_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
PLUGIN_DIR="$(cd "$BIN_DIR/.." >/dev/null 2>&1 && pwd)"
PYTHON_BIN="${RESEARCH_PLUGIN_PYTHON:-python3}"
if [[ -x "$PLUGIN_DIR/.venv/bin/python" ]]; then
  PYTHON_BIN="$PLUGIN_DIR/.venv/bin/python"
fi

export PYTHONPATH="$PLUGIN_DIR${PYTHONPATH:+:$PYTHONPATH}"

# Default to a .env at the plugin root; explicit deployment env always wins.
DEFAULT_MODAL_ENV_FILE="$PLUGIN_DIR/.env"
if [[ -z "${RESEARCH_PLUGIN_MODAL_ENV_FILE:-}" && -f "$DEFAULT_MODAL_ENV_FILE" ]]; then
  export RESEARCH_PLUGIN_MODAL_ENV_FILE="$DEFAULT_MODAL_ENV_FILE"
fi

exec "$PYTHON_BIN" -m backend.http_server "$@"
