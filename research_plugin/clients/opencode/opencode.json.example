{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "research-plugin": {
      "type": "local",
      "command": ["/absolute/path/to/research_plugin/bin/research-plugin-mcp"],
      "enabled": true,
      "environment": {
        "RESEARCH_PLUGIN_DAEMON_URL": "http://127.0.0.1:8787"
      }
    }
  }
}
